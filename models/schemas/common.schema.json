{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-resource-protocol.dev/schemas/common.schema.json",
  "title": "Common Schema Definitions",
  "$defs": {
    "resourceKind": {
      "type": "string",
      "enum": [
        "prompt",
        "agent",
        "tool",
        "environment",
        "memory"
      ]
    },
    "registrationStatus": {
      "type": "string",
      "enum": [
        "active",
        "deprecated",
        "archived",
        "superseded",
        "restored"
      ]
    },
    "lifecycleState": {
      "type": "string",
      "enum": [
        "draft",
        "active",
        "deprecated",
        "archived",
        "superseded",
        "restored"
      ]
    },
    "mutationType": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "restore",
        "fork",
        "import"
      ]
    },
    "auditAction": {
      "type": "string",
      "enum": [
        "create",
        "update",
        "restore",
        "fork",
        "import"
      ]
    },
    "identifier": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "objectMap": {
      "type": "object",
      "additionalProperties": true
    },
    "stringArray": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
