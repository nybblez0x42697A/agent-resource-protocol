{
  "exampleId": "split-control-and-registry",
  "normativeAnchor": "spec/deployment/deployment-topology-and-trust-boundaries.md",
  "description": "Separate endpoint/controller and registry-authority services, with delegated policy evaluation and shared correlation identifiers.",
  "roles": {
