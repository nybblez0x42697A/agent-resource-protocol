      "control-plane-gateway"
    ],
    "resourceAuthority": [
      "registry-authority"
    ],
    "policyAuthority": [
      "policy-service"
    ],
    "auditTraceAuthority": [
      "audit-service"
    ],
    "externalDependency": [
      "managed-resource-store"
    ]
  },
  "trustBoundaries": [
    {
      "type": "callerBoundary",
      "between": [
        "client",
        "control-plane-gateway"
      ]
    },
    {
      "type": "internalServiceBoundary",
      "between": [
        "control-plane-gateway",
        "registry-authority"
      ]
    },
    {
      "type": "delegatedAuthorityBoundary",
      "between": [
        "control-plane-gateway",
        "policy-service"
      ]
    },
    {
      "type": "externalDependencyBoundary",
      "between": [
        "registry-authority",
        "managed-resource-store"
      ]
    }
  ],
  "preservedInvariants": [
    "operationMeaning",
    "authoritativeOutcome",
    "correlationContinuity",
    "boundedDiagnostics"
